# Local daemon
HOST=127.0.0.1
SECOND_PORT=7317
SECOND_DAEMON=localhost:7317
SECOND_DEFAULT_CHANNEL=slack

# Public callback base URL for Slack HTTP mode, for example an HTTPS tunnel.
SECOND_PUBLIC_URL=

# Optional public base URL for mobile PWA pairing links.
# Defaults to SECOND_PUBLIC_URL or the current request origin.
SECOND_MOBILE_PUBLIC_URL=

# Slack credentials. Keep real values in .env or the local settings UI only.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SECOND_SLACK_SOCKET_MODE=0
SECOND_SLACK_DECISION_CHANNEL=
SECOND_SLACK_ALLOWED_USERS=
SECOND_SLACK_ALLOWED_CHANNELS=
SECOND_SLACK_CUSTOMIZE_PROFILE=0

# The browser Settings page can also save the source-adapter secrets under
# .second/secrets/<channel>.json. Environment variables below override local UI values.

# Discord source adapter
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
SECOND_DISCORD_MESSAGE_CONTENT_INTENT=0
SECOND_DISCORD_ALLOWED_USERS=
SECOND_DISCORD_ALLOWED_CHANNELS=

# Telegram source adapter
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SECOND_TELEGRAM_ALLOWED_USERS=
SECOND_TELEGRAM_ALLOWED_CHATS=

# WhatsApp Cloud API source adapter
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
SECOND_WHATSAPP_ALLOWED_USERS=
SECOND_WHATSAPP_ALLOWED_CHATS=

# DingTalk source adapter
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
SECOND_DINGTALK_ALLOWED_USERS=
SECOND_DINGTALK_ALLOWED_CONVERSATIONS=

# Feishu/Lark source adapter
FEISHU_WEBHOOK_URL=
SECOND_FEISHU_ALLOWED_USERS=
SECOND_FEISHU_ALLOWED_CHATS=

# Codex runtime
SECOND_CODEX_NETWORK_ACCESS=0
