# Local daemon
HOST=127.0.0.1
SECOND_PORT=7317
SECOND_DAEMON=localhost:7317
SECOND_DEFAULT_CHANNEL=slack

# Public callback base URL for Slack HTTP mode, for example an HTTPS tunnel.
SECOND_PUBLIC_URL=

# Optional public base URL for mobile PWA pairing links.
# Defaults to SECOND_PUBLIC_URL or the current request origin.
SECOND_MOBILE_PUBLIC_URL=

# Slack credentials. Keep real values in .env or the local settings UI only.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SECOND_SLACK_SOCKET_MODE=0
SECOND_SLACK_DECISION_CHANNEL=
SECOND_SLACK_ALLOWED_USERS=
SECOND_SLACK_ALLOWED_CHANNELS=
SECOND_SLACK_CUSTOMIZE_PROFILE=0

# Codex runtime
SECOND_CODEX_NETWORK_ACCESS=0
